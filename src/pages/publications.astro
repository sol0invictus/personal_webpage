---
import Base from '../layouts/Base.astro';
import { publications, categoryLabels, categoryOrder, type PublicationCategory } from '../data/publications';

const byCategory = new Map<PublicationCategory, typeof publications>();
for (const pub of publications) {
  const list = byCategory.get(pub.category) ?? [];
  list.push(pub);
  byCategory.set(pub.category, list);
}

const sections = categoryOrder
  .filter((cat) => byCategory.has(cat))
  .map((cat) => {
    const pubs = byCategory.get(cat)!.slice().sort((a, b) => b.year - a.year);
    const byYear = new Map<number, typeof publications>();
    for (const pub of pubs) {
      const list = byYear.get(pub.year) ?? [];
      list.push(pub);
      byYear.set(pub.year, list);
    }
    const years = [...byYear.keys()].sort((a, b) => b - a);
    return { category: cat, years, byYear };
  });
---
<Base title="Publications — Sunny Guha" description="Academic publications and preprints.">
  <h1>Publications</h1>
  {sections.length === 0 ? (
    <p>No publications listed yet.</p>
  ) : (
    sections.map(({ category, years, byYear }) => (
      <section style="margin-top: 2em;">
        <h2>{categoryLabels[category]}</h2>
        {years.map((year) => (
          <section style="margin-top: 1em;">
            <h3 style="font-size: 1.05rem; color: var(--fg-muted); margin-bottom: 0.3em;">{year}</h3>
            <ul style="list-style: none; padding: 0; margin: 0.3em 0;">
              {byYear.get(year)!.map((pub) => (
                <li style="margin: 0.9em 0;">
                  <div><strong>{pub.title}</strong></div>
                  <div style="color: var(--fg-muted); font-size: 0.95rem;">{pub.authors}</div>
                  <div style="color: var(--fg-muted); font-size: 0.95rem;">
                    <em>{pub.venue}</em>
                    {pub.note && <span> — {pub.note}</span>}
                  </div>
                  {pub.links && pub.links.length > 0 && (
                    <div style="margin-top: 0.2em; font-size: 0.92rem;">
                      {pub.links.map((l, i) => (
                        <>
                          {i > 0 && <span style="color: var(--fg-muted);"> · </span>}
                          <a href={l.href}>{l.label}</a>
                        </>
                      ))}
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </section>
    ))
  )}
</Base>
