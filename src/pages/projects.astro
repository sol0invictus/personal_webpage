---
import Base from '../layouts/Base.astro';
import { projects } from '../data/projects';

const sorted = [...projects].sort((a, b) => b.year - a.year);
---
<Base title="Projects — Sunny Guha" description="Personal projects and side experiments.">
  <h1>Projects</h1>
  <p>Things I've built outside of academic work.</p>
  <ul class="entry-list">
    {sorted.map((p) => (
      <li>
        <time>{p.year}</time>
        <div>
          <strong>{p.title}</strong>
          <div class="entry-desc">{p.description}</div>
          {p.links && p.links.length > 0 && (
            <div style="margin-top: 0.3em; font-size: 0.92rem;">
              {p.links.map((l, i) => (
                <>
                  {i > 0 && <span style="color: var(--fg-muted);"> · </span>}
                  <a href={l.href} data-sibling-subdomain={l.sibling}>{l.label}</a>
                </>
              ))}
            </div>
          )}
        </div>
      </li>
    ))}
  </ul>
</Base>

<script is:inline>
  (() => {
    const links = document.querySelectorAll('a[data-sibling-subdomain]');
    if (!links.length) return;
    const host = window.location.hostname;
    const parts = host.split('.');
    const base = parts.length >= 3 ? parts.slice(1).join('.') : host;
    links.forEach((a) => {
      const sub = a.getAttribute('data-sibling-subdomain');
      if (sub) a.href = `${window.location.protocol}//${sub}.${base}/`;
    });
  })();
</script>
